FROM ghcr.io/inter-mediator/php-apache_im:latest

RUN apt-get update
RUN apt-get install -y git unzip npm nano
RUN docker-php-ext-install bcmath
RUN rm -rf /var/www/html/*
RUN chown -R www-data /var/www
RUN git clone https://github.com/INTER-Mediator/IMApp_Trial /var/www/html
RUN cd /var/www/html; composer update --no-plugins --no-scripts
RUN cd /var/www/html; composer install
RUN curl -fsSL https://get.pnpm.io/install.sh | sh -
RUN cd /var/www/html/vendor/inter-mediator/inter-mediator; pnpm ci
RUN cd /var/www/html/vendor/inter-mediator/inter-mediator; ./dist-docs/generateminifyjshere.sh
